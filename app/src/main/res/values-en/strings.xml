    <!-- ==================== Privacy Screen ==================== -->
    <string name="privacy_title">Privacy Policy</string>
    <string name="privacy_statement_title">Privacy Policy Statement</string>
    <string name="privacy_agree_button">Agree and Continue</string>
    <string name="privacy_section_1_title">1. Information Collection</string>
    <string name="privacy_section_1_content">This application only collects the following information locally on your device to provide edge gesture functionality:\n• Device basic info (brand, model, Android version) - for logging and issue diagnosis\n• Screen parameters (resolution, density) - for calculating gesture trigger areas\n• Operation logs (gesture triggers, setting changes) - for troubleshooting, keeping only the last 50 entries\n• App list - only for the app switch blacklist feature\nAll data is stored locally on the device and will not be uploaded to any server.</string>
    <string name="privacy_section_2_title">2. Permissions</string>
    <string name="privacy_section_2_content">This application requires the following permissions to implement core features:\n• Accessibility Service - to perform system operations like back, home, and recent tasks\n• Overlay - to display edge gesture trigger areas\n• Usage Access - to get app information for the app switch blacklist\n• Query All Packages - to manage the app switch blacklist\n• Battery Optimization Whitelist - to ensure the gesture service runs continuously in the background\n• Notification - to display service running status notifications</string>
    <string name="privacy_section_3_title">3. Data Storage and Security</string>
    <string name="privacy_section_3_content">• All data is stored only in the local external private directory of the device\n• Operation logs are retained for 3 days, rotated daily, with a maximum of 50 entries\n• App settings are stored using Android DataStore with encryption\n• This application does not connect to the internet, nor does it collect or upload any personal data</string>
    <string name="privacy_section_4_title">4. Third-Party Services</string>
    <string name="privacy_section_4_content">This application does not contain any third-party SDKs or analytics services, does not integrate advertising platforms, and does not share data with any third parties. All functions are completed locally on the device.</string>
    <string name="privacy_section_5_title">5. User Rights</string>
    <string name="privacy_section_5_content">You can at any time:\n• View and modify all locally stored data in the app settings\n• Clear app data to delete all logs and settings\n• Uninstall the app to completely delete all related data</string>

